# ============================================
# CORREO ELECTRÓNICO
# ============================================

# ------------------------------------------------------------
# CUENTA PARA EMAILS AUTOMÁTICOS (noreply@viveverde.es)
# Usada para: verificación de registro, recuperación de contraseña, notificaciones
# ------------------------------------------------------------
EMAIL_HOST="smtp.serviciodecorreo.es"
EMAIL_PORT="465"
EMAIL_SECURE="true"
EMAIL_USER="noreply@viveverde.es"
EMAIL_PASSWORD="CONTRASEÑA_NOREPLY_AQUI"
EMAIL_FROM="Club ViveVerde <noreply@viveverde.es>"
EMAIL_NOREPLY="noreply@viveverde.es"

# ------------------------------------------------------------
# CUENTA PARA FORMULARIO DE AYUDA/CONTACTO (info@viveverde.es)
# Usada para: recibir mensajes del formulario de ayuda
# ------------------------------------------------------------
EMAIL_CONTACT_HOST="smtp.serviciodecorreo.es"
EMAIL_CONTACT_PORT="465"
EMAIL_CONTACT_SECURE="true"
EMAIL_CONTACT_USER="info@viveverde.es"
EMAIL_CONTACT_PASSWORD="CONTRASEÑA_INFO_AQUI"
EMAIL_CONTACT_FROM="Club ViveVerde <info@viveverde.es>"
EMAIL_CONTACT="info@viveverde.es"

# Destinatario legacy (deprecated)
EMAIL_TO="info@viveverde.es"

# ============================================
# AUTENTICACIÓN
# ============================================

JWT_SECRET="TU_JWT_SECRET_AQUI"
NODE_ENV="production"

# ============================================
# DESARROLLO Y DEBUG
# ============================================

# Deshabilita el rate limiting para testing local
# ADVERTENCIA: NUNCA establecer en true en producción
DISABLE_RATE_LIMIT="false"
